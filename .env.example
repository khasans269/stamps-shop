# Пример переменных окружения. Реальные значения задаются в Vercel
# (Project Settings → Environment Variables), а НЕ в этом файле и НЕ в git.
# Скопируйте при локальной разработке в .env.local (он в .gitignore).

# ── Telegram (уведомления о заказах) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Google Sheets (журнал заказов через Apps Script) ─────────────────────────
SHEETS_WEBHOOK_URL=

# ── ЮKassa (приём оплаты) ────────────────────────────────────────────────────
# shopId и секретный ключ из личного кабинета ЮKassa.
# Для теста используйте тестовые shopId/secret (тот же API, тестовый режим).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Фикс-стоимость доставки в рублях (целое число). Включается в итог заказа
# одним платежом. Меняется без передеплоя кода.
DELIVERY_FLAT_FEE=350

# Отправлять ли чек в ЮKassa (автосервис чеков для самозанятых).
# "true"  — передаём объект receipt, ЮKassa формирует чек сама.
# пусто/иное — чек не передаём (пробивается вручную в «Мой налог»).
# Включать ТОЛЬКО после подключения автосервиса чеков в ЛК ЮKassa
# и сверки формата чека (vat_code / payment_subject) — см. docs/payments-setup.md.
YOOKASSA_SEND_RECEIPT=

# ── Доставка: виджет ПВЗ СДЭК на чекауте ─────────────────────────────────────
# Ключ Яндекс.Карт (JavaScript API и HTTP Геокодер) — виджет СДЭК рисует
# карту на Яндекс.Картах, без ключа он не отобразится. Получить бесплатно:
# developer.tech.yandex.ru → «Получить ключ» → «JavaScript API и HTTP Геокодер».
# Обязательно задать HTTP Referrer = адрес сайта. Если не задан — способ
# «СДЭК ПВЗ» показывает «стоимость сообщу отдельно».
YANDEX_MAPS_API_KEY=

# Ключи интеграции СДЭК (для расчёта тарифов). Если не заданы — используются
# ПУБЛИЧНЫЕ ТЕСТОВЫЕ ключи и тестовый хост (расчёт работает, но на тестовых
# данных). Для боевого режима задать все три:
#   CDEK_ACCOUNT / CDEK_SECRET — из ЛК СДЭК (Интеграция → «Создать ключ»);
#   CDEK_API_BASE=https://api.cdek.ru/v2
CDEK_ACCOUNT=
CDEK_SECRET=
CDEK_API_BASE=

# ── Доставка: Яндекс ПВЗ на чекауте ──────────────────────────────────────────
# Виджет Яндекса используем ТОЛЬКО для выбора пункта на карте, а стоимость
# считаем на своём сервере (метод 1.01 pricing-calculator) — иначе цена в
# виджете плавает при блокировке сторонних cookie (инкогнито, Safari).
#
# id склада отгрузки (source_platform_station). Тест (только Москва):
# fbed3aa1-2cc6-4370-ab4d-59c5cc9bb924. Бой — выдаёт менеджер Яндекса.
YANDEX_DELIVERY_SOURCE_STATION_ID=
# Bearer-токен API Яндекс Доставки — нужен для серверного расчёта цены.
# Без него способ «Яндекс ПВЗ» не сможет посчитать стоимость. Из ЛК Яндекс
# Доставки (токен для API-запросов). НИКОГДА не коммитить реальное значение.
YANDEX_DELIVERY_TOKEN=
# Хост API. По умолчанию боевой (b2b-authproxy.taxi.yandex.net). Для теста:
# https://b2b.taxi.tst.yandex.net
YANDEX_DELIVERY_API_BASE=
